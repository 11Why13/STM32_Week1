#include "stm32f10x.h"                  // Device header
#include "Delay.h"
#include "LED.h"
#include "KEY.h"

uint16_t Keynumber;

int main(void)
{
    LED_Init();
    KEY_Init();
    
	while(1)

    {
        Keynumber=KEY_GetNum();
        if(Keynumber==1)
        {
        LED1_Turn();
        }
        if(Keynumber==2)
        {
        LED2_Turn();
        }
    }
}
